{
  "manifest_version": 3,
  "name": "Bookings Extract",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://admin.freetour.com/*"
      ],
      "js": [
        "content_script.js"
      ]
    }
  ]
}